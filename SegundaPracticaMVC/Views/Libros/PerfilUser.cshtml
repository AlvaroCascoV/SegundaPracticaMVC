@using System.Security.Claims

<h1>Bienvenido Sr/Sra @Context.User.Identity.Name</h1>

<ul class="list-group">
    <li class="list-group-item"><strong>Username: </strong>@Context.User.FindFirst(ClaimTypes.Name).Value</li>
    <li class="list-group-item"><strong>Apellido: </strong>@Context.User.FindFirst("Apellido").Value</li> 
    <li class="list-group-item"><strong>Apellido: </strong>@Context.User.FindFirst("Email").Value</li> 
    <li class="list-group-item">
        <img src="~/images/@Context.User.FindFirst("Imagen").Value" style="width:150px" />
    </li>
</ul> 

